{
  "tasks": {
    "lint": "deno fmt && deno lint && deno check",
    "check": "deno lint && deno check && deno fmt --check",
    "dev": "deno task --cwd lume serve"
  },
  "workspace": ["./server", "./lume"],
  "imports": {
    "#/": "./",
    "@hono/hono": "jsr:@hono/hono@^4.12.10",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.14/jsx-runtime.ts",
    "arktype": "npm:arktype@^2.2.0"
  },
  "unstable": [
    "bundle",
    "temporal",
    "fmt-component",
    "kv"
  ],
  "allowScripts": {
    "deny": [
      "npm:sharp"
    ]
  },
  "nodeModulesDir": "auto"
}
