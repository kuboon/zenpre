{
  "tasks": {
    "lint": "deno fmt && deno lint && deno check",
    "check": "deno lint && deno check && deno fmt --check",
    "dev": "deno task --cwd lume serve"
  },
  "workspace": ["./server", "./lume"],
  "imports": {
    "#/": "./",
    "@hono/hono": "jsr:@hono/hono@^4.10.5",
    "@shikijs/rehype": "npm:@shikijs/rehype@^4.0.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "beautiful-mermaid": "npm:beautiful-mermaid@^1.1.3",
    "daisyui": "npm:daisyui@^5.5.19",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.14/jsx-runtime.ts",
    "arktype": "npm:arktype@^2.2.0",
    "rehype-stringify": "npm:rehype-stringify@^10.0.1",
    "remark-parse": "npm:remark-parse@^11.0.0",
    "remark-rehype": "npm:remark-rehype@^11.1.2",
    "shiki": "npm:shiki@^4.0.2",
    "unified": "npm:unified@^11.0.5",
    "unist-util-visit": "npm:unist-util-visit@^5.1.0"
  },
  "unstable": [
    "bundle",
    "temporal",
    "fmt-component",
    "kv"
  ],
  "allowScripts": {
    "deny": [
      "npm:sharp"
    ]
  },
  "nodeModulesDir": "auto"
}
