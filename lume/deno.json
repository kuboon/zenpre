{
  "tasks": {
    "dev": "deno run --watch -P server/main.ts",
    "start": "deno run -P server/main.ts",
    "lume": {
      "description": "Run Lume command",
      "command": "deno run --env -P=lume lume/cli.ts"
    },
    "build": {
      "description": "Build the site for production",
      "command": "deno task lume"
    },
    "serve": {
      "description": "Run the default Lume development server",
      "command": "deno task lume -s"
    },
    "test": {
      "description": "Run tests with test permission profile",
      "command": "deno test -P"
    }
  },
  "compilerOptions": {
    "types": [
      "lume/types.ts"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "lume"
  },
  "imports": {
    "beautiful-mermaid": "npm:beautiful-mermaid@^1.1.3",
    "daisyui": "npm:daisyui@^5.5.19",
    "lume/": "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.2/",
    "lume/cms/": "https://cdn.jsdelivr.net/gh/lumeland/cms@0.14.16/",
    "lume/jsx-runtime": "https://cdn.jsdelivr.net/gh/oscarotero/ssx@0.1.14/jsx-runtime.ts",
    "tailwindcss": "npm:tailwindcss@^4.2.2",
    "unified": "https://esm.sh/unified@11",
    "unist-util-visit": "npm:unist-util-visit@^5.1.0",
    "rehype-stringify": "npm:rehype-stringify@^10.0.1",
    "remark-parse": "npm:remark-parse@^11.0.0",
    "remark-rehype": "npm:remark-rehype@^11.1.2",
    "@shikijs/rehype": "npm:@shikijs/rehype@^4.0.2"
  },
  "fmt": {
    "exclude": ["**/*.vto"]
  },
  "lint": {
    "plugins": [
      "https://cdn.jsdelivr.net/gh/lumeland/lume@3.2.2/lint.ts"
    ],
    "rules": {
      "exclude": [
        "no-import-prefix"
      ]
    }
  },
  "permissions": {
    "lume": {
      "read": true,
      "write": [
        "../",
        "$HOME/.cache/",
        "$DENO_DIR/"
      ],
      "import": [
        "cdn.jsdelivr.net:443",
        "jsr.io:443",
        "deno.land:443",
        "esm.sh:443"
      ],
      "net": [
        "0.0.0.0",
        "jsr.io:443",
        "cdn.jsdelivr.net:443",
        "esm.sh:443",
        "data.jsdelivr.com:443",
        "registry.npmjs.org:443"
      ],
      "env": {
        "allow": [
          "DENO_DIR"
        ],
        "ignore": true
      },
      "run": true,
      "ffi": true,
      "sys": true
    }
  },
  "test": {
    "permissions": "lume"
  }
}
