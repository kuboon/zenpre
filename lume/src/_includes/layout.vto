<!DOCTYPE html>
<html lang="{{metas.lang}}">
  <head>
    <meta charset="UTF-8">
    <title>{{ title }} | {{ metas.site }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style/main.css">
    <meta name="twitter:title" content="{{ title }} | {{ metas.site }}">
    <meta name="twitter:description" content="{{ description }}">
    <meta name="twitter:image" content="{{ '/ogp.png' |> url(true) }}">
  </head>
  <body class="bg-background text-foreground">
  {{ comp drawer }}
    <header
      class="sticky top-0 z-50 w-full bg-background/95 backdrop-blur"
    >
      <div class="mx-auto w-full max-w-7xl">
        <div class="flex items-center h-14 px-4">
          <div class="flex-1">
            <a
              href='{{ "/" |> url }}'
              class="inline-block font-bold text-xl"
            >
              <img
                src="{{ '/logo.png' |> url }}"
                alt="ZenPre"
                class="inline h-14 -ms-2"
              />
            </a>
          </div>
          <div class="flex gap-2">
            <label for="my-drawer" class="btn drawer-button lg:hidden">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                class="inline-block h-5 w-5 stroke-current"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"
                >
                </path>
              </svg>
            </label>
          </div>
        </div>
      </div>
    </header>

    <main class="m-4">{{ content }}</main>

    {{ comp.footer() }}
  {{ /comp }}
  </body>
</html>
